# =============================================================================
# Docker Compose 环境变量配置
# =============================================================================
# 用途：配置所有服务的默认参数
# 使用方式：复制此文件为 .env 后根据需要修改
# =============================================================================

# 项目名称（影响容器和卷的前缀）
COMPOSE_PROJECT_NAME=demo

# =============================================================================
# Database Services
# =============================================================================

# MySQL
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=demo_db
MYSQL_USER=demo_user
MYSQL_PASSWORD=demo_password

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=demo_password
POSTGRES_DB=demo_db

# Redis
REDIS_PORT=6379

# =============================================================================
# Monitoring Services
# =============================================================================

# Grafana
GRAFANA_PORT=3000

# Prometheus
PROMETHEUS_PORT=9090

# Tempo
TEMPO_API_PORT=3200
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318

# Loki
LOKI_PORT=3100

# OpenTelemetry Collector
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_PORT=9464
OTEL_INTERNAL_METRICS_PORT=8888
OTEL_HEALTH_PORT=13133

# =============================================================================
# Application
# =============================================================================

APP_PORT=8080
APP_ENV=development

# OpenTelemetry
OTEL_SERVICE_NAME=demo-go-framework
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
