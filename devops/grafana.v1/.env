# =============================================================================
# Grafana v1 监控栈环境变量配置
# =============================================================================
# 使用方式：cp .env.example .env 后根据需要修改
# =============================================================================

# 项目名称（影响容器和卷的前缀）
COMPOSE_PROJECT_NAME=demo

# Grafana
GRAFANA_PORT=3000

# Prometheus
PROMETHEUS_PORT=9090

# Tempo
TEMPO_API_PORT=3200
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318

# Loki
LOKI_PORT=3100

# OpenTelemetry Collector
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_PORT=9464
OTEL_INTERNAL_METRICS_PORT=8888
OTEL_HEALTH_PORT=13133
