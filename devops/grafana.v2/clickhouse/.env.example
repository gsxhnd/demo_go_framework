# =============================================================================
# ClickHouse 环境变量配置
# =============================================================================
# 使用方式：cp .env.example .env 后根据需要修改
# =============================================================================

# 项目名称（影响容器和卷的前缀）
COMPOSE_PROJECT_NAME=demo

# ClickHouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000
