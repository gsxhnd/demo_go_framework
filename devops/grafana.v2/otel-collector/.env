# =============================================================================
# OTel Collector (Grafana v2) 环境变量配置
# =============================================================================
# 使用方式：cp .env.example .env 后根据需要修改
# 注意：端口与 grafana.v1 的 OTel Collector 错开，避免冲突
# =============================================================================

# 项目名称（影响容器和卷的前缀）
COMPOSE_PROJECT_NAME=demo

# OTLP gRPC 接收端口（grafana.v1 占用 4317，此处默认 4319）
OTEL_V2_GRPC_PORT=4317

# OTLP HTTP 接收端口（grafana.v1 占用 4318，此处默认 4320）
OTEL_V2_HTTP_PORT=4318

# Collector 自身 metrics 端口（grafana.v1 占用 8888，此处默认 8889）
OTEL_V2_INTERNAL_METRICS_PORT=8888

# Health check 端口（grafana.v1 占用 13133，此处默认 13134）
OTEL_V2_HEALTH_PORT=13133
